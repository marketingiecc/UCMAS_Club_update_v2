## Copy this file to `.env.local` and replace values.
## Restart `npm run dev` after updating env.

# Google Cloud Text-to-Speech API key (used by Nghe tinh test + stable TTS fallback)
VITE_GOOGLE_TTS_API_KEY=YOUR_GOOGLE_CLOUD_TTS_API_KEY

# Optional: FPT AI TTS key (for FPT engine)
VITE_FPT_AI_API_KEY=YOUR_FPT_AI_API_KEY

# Legacy fallback key names (optional)
GEMINI_API_KEY=
API_KEY=
