## Copy this file to `.env.local` and replace values.
## Restart `npm run dev` after updating env.

# Google Cloud Text-to-Speech API key (used by Nghe tinh test + stable TTS fallback)
VITE_GOOGLE_TTS_API_KEY=YOUR_GOOGLE_CLOUD_TTS_API_KEY

# Optional: FPT AI TTS key (for FPT engine)
VITE_FPT_AI_API_KEY=YOUR_FPT_AI_API_KEY

# Legacy fallback key names (optional)
GEMINI_API_KEY=
API_KEY=

## DEPLOYMENT (Vercel / Netlify / GitHub Pages)
## .env.local is gitignored – add env vars in your hosting dashboard:
##
## - Vercel: Project → Settings → Environment Variables → VITE_GOOGLE_TTS_API_KEY
## - Netlify: Site settings → Build & deploy → Environment → VITE_GOOGLE_TTS_API_KEY
## - GitHub Pages (Actions): Repo → Settings → Secrets → add secret, then in workflow:
##     env: VITE_GOOGLE_TTS_API_KEY: ${{ secrets.VITE_GOOGLE_TTS_API_KEY }}
